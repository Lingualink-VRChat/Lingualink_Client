{
  "$schema": "http://json.schemastore.org/launchsettings.json",
  "profiles": {
    "lingualink_client (Dev)": {
      "commandName": "Project",
      "environmentVariables": {
        "LINGUALINK_AUTH_SERVER_URL": "http://<YOUR_SERVER_IP>:19080",
        "LINGUALINK_CORE_SERVER_URL": "http://<YOUR_SERVER_IP>:8100/api/v1/"
      }
    },
    "lingualink_client (Prod)": {
      "commandName": "Project",
      "environmentVariables": {}
    }
  }
}
