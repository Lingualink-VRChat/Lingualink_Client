<Page
    x:Class="lingualink_client.Views.AccountPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:lingualink_client.ViewModels"
    Title="AccountPage"
    d:DataContext="{d:DesignInstance Type=vm:AccountPageViewModel}"
    d:DesignHeight="820"
    d:DesignWidth="840"
    mc:Ignorable="d">
    <ui:PassiveScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="{DynamicResource PageContentMargin}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <ui:Card Grid.Row="0" Margin="0,0,0,20" Padding="24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Width="64"
                        Height="64"
                        Margin="0,4,0,0"
                        VerticalAlignment="Top"
                        CornerRadius="32"
                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                        <Grid>
                            <ui:SymbolIcon
                                FontSize="48"
                                Symbol="PersonCircle24"
                                Visibility="{Binding IsLoggedIn, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=invert}" />
                            <ui:SymbolIcon
                                FontSize="32"
                                Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                Symbol="Person24"
                                Visibility="{Binding IsLoggedIn, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="24,0,0,0">
                        <StackPanel Visibility="{Binding IsLoggedIn, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=invert}">
                            <ui:TextBlock
                                Margin="0,0,0,4"
                                FontSize="20"
                                FontWeight="SemiBold"
                                Text="{Binding OfficialServiceLoginLabel}" />

                            <ui:TextBlock
                                Margin="0,0,0,20"
                                FontSize="14"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Text="{Binding OfficialServiceSubtitleLabel}" />

                            <StackPanel Orientation="Horizontal">
                                <ui:Button
                                    Width="140"
                                    Appearance="Primary"
                                    Command="{Binding LoginCommand}"
                                    Content="{Binding LoginLabel}"
                                    Icon="{ui:SymbolIcon Person24}" />

                                <ui:ProgressRing
                                    Width="24"
                                    Height="24"
                                    Margin="16,0,0,0"
                                    IsIndeterminate="True"
                                    Visibility="{Binding IsLoggingIn, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsLoggedIn, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ui:TextBlock
                                Margin="0,0,0,8"
                                FontSize="20"
                                FontWeight="SemiBold"
                                Text="{Binding LoggedInUsername}" />

                            <StackPanel Margin="0,0,0,16">
                                <StackPanel Orientation="Horizontal">
                                    <Border
                                        Padding="8,4"
                                        Background="{DynamicResource AccentFillColorDefaultBrush}"
                                        CornerRadius="4"
                                        Visibility="{Binding SubscriptionStatus, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock
                                            FontSize="12"
                                            FontWeight="Medium"
                                            Foreground="White"
                                            Text="{Binding SubscriptionStatus}" />
                                    </Border>
                                    <ui:TextBlock
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="13"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                        Visibility="{Binding CurrentPlanDisplay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Run Text="{Binding CurrentPlanPrefixLabel, Mode=OneWay}" />
                                        <Run Text="{Binding CurrentPlanDisplay, Mode=OneWay}" />
                                    </ui:TextBlock>
                                </StackPanel>

                                <ui:TextBlock
                                    Margin="0,6,0,0"
                                    FontSize="12"
                                    Foreground="{DynamicResource SystemFillColorCautionBrush}"
                                    Text="{Binding ExpiryReminder}"
                                    TextWrapping="Wrap"
                                    Visibility="{Binding ExpiryReminder, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <ui:Button
                                    Width="132"
                                    Appearance="Primary"
                                    Command="{Binding OpenSubscriptionDialogCommand}"
                                    Content="{Binding VipActionButtonText}"
                                    Icon="{ui:SymbolIcon Person24}" />
                                <ui:Button
                                    Width="100"
                                    Margin="12,0,0,0"
                                    Appearance="Secondary"
                                    Command="{Binding RefreshUserProfileCommand}"
                                    Content="{Binding RefreshLabel}"
                                    Icon="{ui:SymbolIcon ArrowSync24}"
                                    ToolTip="{Binding RefreshProfileTooltipLabel}" />
                                <ui:Button
                                    Width="100"
                                    Margin="12,0,0,0"
                                    Appearance="Secondary"
                                    Command="{Binding LogoutCommand}"
                                    Content="{Binding LogoutLabel}"
                                    Icon="{ui:SymbolIcon SignOut24}" />
                                <ui:ProgressRing
                                    Width="20"
                                    Height="20"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    IsIndeterminate="True"
                                    Visibility="{Binding IsUpdatingUserProfile, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </StackPanel>

                            <Border
                                Margin="0,16,0,0"
                                Padding="12"
                                Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                                CornerRadius="8">
                                <StackPanel>
                                    <ui:TextBlock FontSize="14" FontWeight="SemiBold" Text="{Binding SubscriptionOverviewLabel}" />
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <ui:TextBlock Grid.Row="0" Grid.Column="0" FontWeight="Medium" Text="{Binding SubscriptionCurrentStatusLabel}" />
                                        <ui:TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SubscriptionStatus}" />

                                        <ui:TextBlock Grid.Row="1" Grid.Column="0" Margin="0,6,0,0" FontWeight="Medium" Text="{Binding SubscriptionCurrentPlanLabel}" />
                                        <ui:TextBlock Grid.Row="1" Grid.Column="1" Margin="0,6,0,0" Text="{Binding CurrentPlanDisplay}" />

                                        <ui:TextBlock Grid.Row="2" Grid.Column="0" Margin="0,6,0,0" FontWeight="Medium" Text="{Binding SubscriptionRemainingLabel}" />
                                        <ui:TextBlock Grid.Row="2" Grid.Column="1" Margin="0,6,0,0" Text="{Binding SubscriptionRemainingDisplay}" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border
                                Margin="0,16,0,0"
                                Padding="12"
                                Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                                CornerRadius="8">
                                <StackPanel>
                                    <ui:TextBlock FontSize="14" FontWeight="SemiBold" Text="{Binding PersonalInfoLabel}" />

                                    <Border
                                        Margin="0,10,0,0"
                                        Padding="10"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        CornerRadius="6">
                                        <StackPanel>
                                            <Grid Visibility="{Binding IsEditingUsername, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=invert}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="100" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ui:TextBlock VerticalAlignment="Center" FontWeight="Medium" Text="{Binding UsernameLabel}" />
                                                <ui:TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding UsernameDisplay}" />
                                                <ui:Button Grid.Column="2" Width="72" Height="32" Appearance="Secondary" Command="{Binding BeginEditUsernameCommand}" Content="{Binding EditLabel}" />
                                            </Grid>
                                            <StackPanel Visibility="{Binding IsEditingUsername, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <ui:TextBox
                                                    Height="36"
                                                    VerticalContentAlignment="Center"
                                                    PlaceholderText="{Binding UsernamePlaceholderLabel}"
                                                    Text="{Binding EditUsername, UpdateSourceTrigger=PropertyChanged}" />
                                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                    <ui:Button Width="72" Height="32" Appearance="Primary" Command="{Binding SaveUsernameCommand}" Content="{Binding SaveLabel}" />
                                                    <ui:Button Width="72" Height="32" Margin="8,0,0,0" Appearance="Secondary" Command="{Binding CancelEditUsernameCommand}" Content="{Binding CancelLabel}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <Border
                                        Margin="0,8,0,0"
                                        Padding="10"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        CornerRadius="6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <ui:TextBlock VerticalAlignment="Center" FontWeight="Medium" Text="{Binding AccountStatusLabel}" />
                                            <ui:TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding UserStatusDisplay}" />
                                        </Grid>
                                    </Border>

                                    <ui:TextBlock Margin="0,12,0,0" FontSize="13" FontWeight="SemiBold" Text="{Binding AccountSecurityLabel}" />

                                    <Border
                                        Margin="0,8,0,0"
                                        Padding="10"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        CornerRadius="6">
                                        <StackPanel>
                                            <Grid Visibility="{Binding IsEditingEmail, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=invert}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="100" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ui:TextBlock VerticalAlignment="Center" FontWeight="Medium" Text="{Binding EmailLabel}" />
                                                <ui:TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding EmailDisplay}" />
                                                <ui:Button Grid.Column="2" Width="72" Height="32" Appearance="Secondary" Command="{Binding BeginEditEmailCommand}" Content="{Binding EmailActionButtonText}" />
                                            </Grid>
                                            <StackPanel Visibility="{Binding IsEditingEmail, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <ui:TextBox
                                                    Height="36"
                                                    VerticalContentAlignment="Center"
                                                    IsReadOnly="{Binding IsEmailCodeSent}"
                                                    PlaceholderText="{Binding EmailPlaceholderLabel}"
                                                    Text="{Binding BindEmailInput, UpdateSourceTrigger=PropertyChanged}" />
                                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                    <ui:Button
                                                        Width="110"
                                                        Height="32"
                                                        Appearance="Secondary"
                                                        Command="{Binding SendEmailCodeCommand}"
                                                        Content="{Binding SendEmailCodeButtonText}" />
                                                    <ui:TextBlock
                                                        Margin="10,0,0,0"
                                                        VerticalAlignment="Center"
                                                        FontSize="12"
                                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                        Text="{Binding EmailCodeLockHintLabel}"
                                                        TextWrapping="Wrap" />
                                                </StackPanel>
                                                <ui:TextBox
                                                    Margin="0,10,0,0"
                                                    Height="36"
                                                    VerticalContentAlignment="Center"
                                                    PlaceholderText="{Binding EmailCodePlaceholderLabel}"
                                                    Text="{Binding BindEmailCodeInput, UpdateSourceTrigger=PropertyChanged}" />
                                                <ui:PasswordBox
                                                    Margin="0,10,0,0"
                                                    Height="36"
                                                    PlaceholderText="{Binding PasswordPlaceholderLabel}"
                                                    Password="{Binding BindEmailPasswordInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <ui:PasswordBox
                                                    Margin="0,10,0,0"
                                                    Height="36"
                                                    PlaceholderText="{Binding ConfirmPasswordPlaceholderLabel}"
                                                    Password="{Binding BindEmailConfirmPasswordInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                    <ui:Button Width="88" Height="32" Appearance="Primary" Command="{Binding SaveEmailCommand}" Content="{Binding BindEmailLabel}" />
                                                    <ui:Button Width="72" Height="32" Margin="8,0,0,0" Appearance="Secondary" Command="{Binding CancelEditEmailCommand}" Content="{Binding CancelLabel}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <ui:TextBlock Margin="0,12,0,0" FontSize="13" FontWeight="SemiBold" Text="{Binding ProviderBindingsLabel}" />

                                    <Border
                                        Margin="0,8,0,0"
                                        Padding="10"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        CornerRadius="6">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="60" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <ui:TextBlock
                                                    Grid.Row="0"
                                                    Grid.Column="0"
                                                    VerticalAlignment="Center"
                                                    FontWeight="Medium"
                                                    Text="{Binding WechatLabel}" />
                                                <ui:TextBlock
                                                    Grid.Row="0"
                                                    Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Text="{Binding WechatBindingStatusDisplay}" />
                                                <ui:TextBlock
                                                    Grid.Row="1"
                                                    Grid.Column="0"
                                                    Margin="0,6,0,0"
                                                    VerticalAlignment="Center"
                                                    FontWeight="Medium"
                                                    Text="{Binding QqLabel}" />
                                                <ui:TextBlock
                                                    Grid.Row="1"
                                                    Grid.Column="1"
                                                    Margin="0,6,0,0"
                                                    VerticalAlignment="Center"
                                                    Text="{Binding QqBindingStatusDisplay}" />
                                            </Grid>
                                            <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                                                <ui:Button
                                                    Width="112"
                                                    Height="32"
                                                    Appearance="Secondary"
                                                    Command="{Binding BindQqProviderCommand}"
                                                    Content="{Binding BindQqLabel}"
                                                    ToolTip="{Binding BindQqTooltipLabel}" />
                                                <ui:Button
                                                    Width="112"
                                                    Height="32"
                                                    Margin="10,0,0,0"
                                                    Appearance="Secondary"
                                                    Command="{Binding BindWechatProviderCommand}"
                                                    Content="{Binding BindWechatLabel}"
                                                    ToolTip="{Binding BindWechatTooltipLabel}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </ui:Card>

            <StackPanel Grid.Row="1" Margin="0,0,0,12">
                <ui:TextBlock
                    Margin="0,0,0,8"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Text="{Binding AdvancedOptionsLabel}" />
            </StackPanel>

            <ui:CardExpander
                Grid.Row="2"
                Margin="0,0,0,24"
                Icon="{ui:SymbolIcon Server24}"
                IsExpanded="{Binding UseCustomServer, Mode=OneWay}">
                <ui:CardExpander.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock FontSize="14" FontWeight="Medium" Text="{Binding UseCustomServerLabel}" />
                            <TextBlock
                                Margin="0,2,0,0"
                                FontSize="12"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Text="{Binding UseCustomServerHint}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding UseCustomServer, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </ui:CardExpander.Header>

                <StackPanel Margin="0,10,0,0" IsEnabled="{Binding UseCustomServer}">
                    <StackPanel Margin="0,0,0,16">
                        <Label Margin="0,0,0,6" Content="{Binding ServerUrlLabel}" />
                        <ui:TextBox
                            Height="36"
                            VerticalContentAlignment="Center"
                            PlaceholderText="{Binding ServerUrlPlaceholderLabel}"
                            Text="{Binding ServerUrl, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Margin="0,0,0,16">
                        <Label Margin="0,0,0,6" Content="{Binding ApiKeyLabel}" />
                        <ui:TextBox
                            Height="36"
                            VerticalContentAlignment="Center"
                            PlaceholderText="{Binding ApiKeyPlaceholderLabel}"
                            Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <ui:Button
                            Width="140"
                            Appearance="Secondary"
                            Command="{Binding TestConnectionCommand}"
                            Content="{Binding ConnectionTestLabel}"
                            Icon="{ui:SymbolIcon PlugConnected24}" />
                        <ui:TextBlock
                            Margin="16,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="{Binding ConnectionTestHintLabel}" />
                    </StackPanel>
                </StackPanel>
            </ui:CardExpander>
        </Grid>
    </ui:PassiveScrollViewer>
</Page>
