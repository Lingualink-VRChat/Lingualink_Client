<Page
    x:Class="lingualink_client.Views.AccountPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:lingualink_client.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:lingualink_client.ViewModels"
    Title="AccountPage"
    d:DataContext="{d:DesignInstance Type=vm:AccountPageViewModel}"
    d:DesignHeight="800"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <ui:PassiveScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="{DynamicResource PageContentMargin}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- 用户信息/登录卡片 -->
                <RowDefinition Height="Auto" /> <!-- API Key 管理（登录后显示） -->
                <RowDefinition Height="Auto" /> <!-- 高级选项分隔 -->
                <RowDefinition Height="Auto" /> <!-- 自定义服务设置 -->
                <RowDefinition Height="*" />   <!-- 占位符 -->
            </Grid.RowDefinitions>

            <!-- ==================== 1. 用户信息/登录卡片 ==================== -->
            <ui:Card
                Grid.Row="0"
                Margin="0,0,0,20"
                Padding="24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 用户头像区域 -->
                    <Border Width="64" Height="64" CornerRadius="32" 
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            VerticalAlignment="Top" Margin="0,4,0,0">
                        <Grid>
                            <!-- 未登录时显示默认图标 -->
                            <ui:SymbolIcon Symbol="PersonCircle24" 
                                           FontSize="48"
                                           Visibility="{Binding IsLoggedIn, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=invert}"/>
                            
                            <!-- 登录后显示用户图标 -->
                            <ui:SymbolIcon Symbol="Person24" 
                                           FontSize="32"
                                           Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                           Visibility="{Binding IsLoggedIn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </Grid>
                    </Border>
                    
                    <StackPanel Grid.Column="1" Margin="24,0,0,0">
                        <!-- ========== 未登录状态 ========== -->
                        <StackPanel Visibility="{Binding IsLoggedIn, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=invert}">
                        <!-- 标题和副标题 -->
                        <ui:TextBlock
                            FontSize="20"
                            FontWeight="SemiBold"
                            Text="{Binding OfficialServiceLoginLabel}"
                            Margin="0,0,0,4" />
                        
                        <ui:TextBlock
                            FontSize="14"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="{Binding OfficialServiceSubtitleLabel}"
                            Margin="0,0,0,20" />

                            <!-- 登录按钮组 -->
                            <StackPanel Orientation="Horizontal">
                                <ui:Button
                                    Width="140"
                                    Appearance="Primary"
                                    Icon="{ui:SymbolIcon Person24}"
                                    Content="{Binding LoginLabel}"
                                    Command="{Binding LoginCommand}"/>
                                
                                <!-- 登录中指示器 -->
                                <ui:ProgressRing
                                    Width="24"
                                    Height="24"
                                    Margin="16,0,0,0"
                                    IsIndeterminate="True"
                                    Visibility="{Binding IsLoggingIn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                            </StackPanel>

                        <!-- ========== 已登录状态 ========== -->
                        <StackPanel Visibility="{Binding IsLoggedIn, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <!-- 用户名 -->
                            <ui:TextBlock
                                FontSize="20"
                                FontWeight="SemiBold"
                                Text="{Binding LoggedInUsername}"
                                Margin="0,0,0,8" />
                            
                            <!-- 订阅信息 -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Background="{DynamicResource AccentFillColorDefaultBrush}" 
                                        CornerRadius="4" 
                                        Padding="8,4"
                                        Visibility="{Binding SubscriptionStatus, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="{Binding SubscriptionStatus}" 
                                               Foreground="White" 
                                               FontSize="12" 
                                               FontWeight="Medium"/>
                                </Border>
                                <ui:TextBlock
                                    Margin="12,0,0,0"
                                    FontSize="13"
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Visibility="{Binding QuotaDisplay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Run Text="配额: "/><Run Text="{Binding QuotaDisplay}"/>
                                </ui:TextBlock>
                            </StackPanel>

                            <!-- 操作按钮 -->
                            <StackPanel Orientation="Horizontal">
                                <ui:Button
                                    Width="100"
                                    Appearance="Secondary"
                                    Icon="{ui:SymbolIcon ArrowSync24}"
                                    Content="刷新"
                                    Command="{Binding RefreshUserProfileCommand}"
                                    ToolTip="刷新用户信息"/>
                                <ui:Button
                                    Width="100"
                                    Margin="12,0,0,0"
                                    Appearance="Secondary"
                                    Icon="{ui:SymbolIcon SignOut24}"
                                    Content="{Binding LogoutLabel}"
                                    Command="{Binding LogoutCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </ui:Card>

            <!-- ==================== 2. API Key 管理（登录后显示） ==================== -->
            <ui:Card
                                Grid.Row="1"
                Margin="0,0,0,20"
                Padding="20"
                Visibility="{Binding IsLoggedIn, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- 标题 -->
                        <RowDefinition Height="Auto"/> <!-- 创建新 Key -->
                        <RowDefinition Height="Auto"/> <!-- 新创建的 Key 显示 -->
                        <RowDefinition Height="Auto"/> <!-- Key 列表 -->
                    </Grid.RowDefinitions>

                    <!-- 标题 -->
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <ui:SymbolIcon Symbol="Key24" FontSize="20"/>
                            <ui:TextBlock
                                Margin="8,0,0,0"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Text="API Key 管理"
                                VerticalAlignment="Center"/>
                        </StackPanel>
                                <ui:Button
                            HorizontalAlignment="Right"
                            Appearance="Transparent"
                            Icon="{ui:SymbolIcon ArrowSync24}"
                            Command="{Binding LoadApiKeysCommand}"
                            ToolTip="刷新列表"/>
                    </Grid>

                    <!-- 创建新 API Key -->
                    <Grid Grid.Row="1" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ui:TextBox
                            Grid.Column="0"
                                    Margin="0,0,12,0"
                            PlaceholderText="输入 API Key 名称（如：我的电脑）"
                            Text="{Binding NewApiKeyName, UpdateSourceTrigger=PropertyChanged}"/>
                                <ui:Button
                            Grid.Column="1"
                                    Width="100"
                            Appearance="Primary"
                            Icon="{ui:SymbolIcon Add24}"
                            Content="创建"
                            Command="{Binding CreateApiKeyCommand}"
                            IsEnabled="{Binding IsCreatingApiKey, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=invert}"/>
                    </Grid>

                    <!-- 新创建的 API Key 显示（一次性显示） -->
                    <Border
                        Grid.Row="2"
                        Margin="0,0,0,16"
                        Background="{DynamicResource SystemFillColorSuccessBackgroundBrush}"
                        CornerRadius="8"
                        Padding="16"
                        Visibility="{Binding ShowNewApiKeyDialog, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- 标题和关闭按钮 -->
                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="CheckmarkCircle24" Foreground="{DynamicResource SystemFillColorSuccessBrush}"/>
                                    <TextBlock Text="API Key 创建成功！" FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <ui:Button
                                    HorizontalAlignment="Right"
                                    Appearance="Transparent"
                                    Icon="{ui:SymbolIcon Dismiss24}"
                                    Command="{Binding CloseNewApiKeyDialogCommand}"
                                    ToolTip="关闭"/>
                            </Grid>
                            
                            <!-- 提示信息 -->
                            <TextBlock 
                                Grid.Row="1" 
                                Text="请立即复制保存，此密钥只显示一次。" 
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Margin="0,0,0,12"/>
                            
                            <!-- API Key 显示和复制 -->
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ui:TextBox 
                                    Grid.Column="0"
                                    Text="{Binding NewlyCreatedApiKey, Mode=OneWay}" 
                                    FontFamily="Consolas"
                                    FontSize="13"
                                    IsReadOnly="True"
                                    Margin="0,0,8,0"/>
                                <ui:Button
                                    Grid.Column="1"
                                    Width="80"
                                    Appearance="Primary"
                                    Icon="{ui:SymbolIcon Copy24}"
                                    Content="复制"
                                    Command="{Binding CopyApiKeyToClipboardCommand}"
                                    CommandParameter="{Binding NewlyCreatedApiKey}"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- API Key 列表 -->
                    <Grid Grid.Row="3">
                        <!-- 加载中 -->
                        <StackPanel 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center"
                            Visibility="{Binding IsLoadingApiKeys, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ui:ProgressRing Width="32" Height="32" IsIndeterminate="True"/>
                            <TextBlock Text="加载中..." Margin="0,8,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <!-- Key 列表 -->
                        <ItemsControl 
                            ItemsSource="{Binding ApiKeys}"
                            Visibility="{Binding IsLoadingApiKeys, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=invert}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border 
                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        CornerRadius="8"
                                        Padding="16,12"
                                        Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <!-- Key 名称和前缀 -->
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock 
                                                        Text="{Binding Name}" 
                                                        FontWeight="Medium"
                                                        FontSize="14"/>
                                                    <Border 
                                                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                        CornerRadius="4"
                                                        Padding="6,2"
                                                        Margin="8,0,0,0">
                                                        <TextBlock 
                                                            Text="{Binding MaskedKey}" 
                                                            FontFamily="Consolas"
                                                            FontSize="12"
                                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                    </Border>
                                                </StackPanel>
                                                
                                                <!-- 创建时间和最后使用时间 -->
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock 
                                                        FontSize="12"
                                                        Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                                                        <Run Text="创建于 "/>
                                                        <Run Text="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}"/>
                                                    </TextBlock>
                                                    <TextBlock 
                                                        Margin="16,0,0,0"
                                                        FontSize="12"
                                                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                        Visibility="{Binding LastUsedAt, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <Run Text="最后使用 "/>
                                                        <Run Text="{Binding LastUsedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}"/>
                                                    </TextBlock>
                                                </StackPanel>
                            </StackPanel>

                                            <!-- 删除按钮 -->
                                            <ui:Button
                                                Grid.Column="1"
                                                Appearance="Secondary"
                                                Icon="{ui:SymbolIcon Delete24}"
                                                ToolTip="删除此 API Key"
                                                Command="{Binding DataContext.DeleteApiKeyCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"/>
                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 空状态 -->
                        <StackPanel 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center"
                            Margin="0,20"
                            Visibility="{Binding ApiKeys.Count, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=invert}">
                            <ui:SymbolIcon Symbol="Key24" FontSize="32" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                            <TextBlock 
                                Text="暂无 API Key" 
                                Margin="0,8,0,0" 
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                HorizontalAlignment="Center"/>
                            <TextBlock 
                                Text="创建一个 API Key 开始使用翻译服务" 
                                FontSize="12"
                                Margin="0,4,0,0" 
                                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                HorizontalAlignment="Center"/>
                    </StackPanel>
                    </Grid>
                </Grid>
            </ui:Card>

            <!-- ==================== 3. 高级选项分隔线 ==================== -->
            <StackPanel Grid.Row="2" Margin="0,0,0,12">
                <ui:TextBlock
                    FontSize="14"
                    FontWeight="SemiBold"
                    Text="{Binding AdvancedOptionsLabel}"
                    Margin="0,0,0,8" />
            </StackPanel>

            <!-- ==================== 4. 自定义服务器选项 ==================== -->
            <ui:CardExpander
                Grid.Row="3"
                Margin="0,0,0,24"
                IsExpanded="{Binding UseCustomServer, Mode=OneWay}"
                Icon="{ui:SymbolIcon Server24}">
                <ui:CardExpander.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding UseCustomServerLabel}" FontWeight="Medium" FontSize="14"/>
                            <TextBlock Text="{Binding UseCustomServerHint}" 
                                     FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                     TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                        <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding UseCustomServer, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </ui:CardExpander.Header>
                
                <StackPanel Margin="0,10,0,0" IsEnabled="{Binding UseCustomServer}">
                    <!-- 服务器 URL -->
                    <StackPanel Margin="0,0,0,16">
                        <Label Content="{Binding ServerUrlLabel}" Margin="0,0,0,6"/>
                        <ui:TextBox
                            Height="36"
                            VerticalContentAlignment="Center"
                            Text="{Binding ServerUrl, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="https://api2.lingualink.aiatechco.com/api/v1/" />
                    </StackPanel>

                    <!-- API 密钥 -->
                    <StackPanel Margin="0,0,0,16">
                        <Label Content="{Binding ApiKeyLabel}" Margin="0,0,0,6"/>
                        <ui:PasswordBox
                            x:Name="ApiKeyPasswordBox"
                            Password="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}"
                            PasswordChanged="ApiKeyPasswordBox_PasswordChanged"
                            PlaceholderText="Enter your API key here" />
                    </StackPanel>

                    <!-- 测试连接按钮 -->
                    <StackPanel Orientation="Horizontal">
                        <ui:Button
                            Width="140"
                            Content="{Binding ConnectionTestLabel}"
                            Appearance="Secondary"
                            Icon="{ui:SymbolIcon PlugConnected24}"
                            Command="{Binding TestConnectionCommand}" />
                        <ui:TextBlock
                            Margin="16,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="Click to test your server connection" />
                    </StackPanel>
                </StackPanel>
            </ui:CardExpander>
        </Grid>
    </ui:PassiveScrollViewer>
</Page>
