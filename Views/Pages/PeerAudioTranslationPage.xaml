<Page
    x:Class="lingualink_client.Views.PeerAudioTranslationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:lingualink_client.ViewModels"
    Title="PeerAudioTranslationPage"
    d:DataContext="{d:DesignInstance Type=vm:PeerAudioTranslationWindowViewModel}"
    mc:Ignorable="d">

    <Grid Margin="{DynamicResource PageContentMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16"
            Margin="0,0,0,12">
            <StackPanel>
                <TextBlock
                    Text="{Binding WindowTitle}"
                    FontSize="20"
                    FontWeight="SemiBold" />
                <TextBlock
                    Margin="0,6,0,0"
                    Text="{Binding Description}"
                    TextWrapping="Wrap"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Border>

        <Border
            Grid.Row="1"
            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16"
            Margin="0,0,0,12">
            <StackPanel>
                <Border
                    Margin="0,0,0,14"
                    Padding="16"
                    Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Visibility="{Binding IsMemberOnlyNoticeVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <ui:SymbolIcon
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                            FontSize="18"
                            Symbol="Info24" />

                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock
                                FontSize="14"
                                FontWeight="SemiBold"
                                Text="{Binding MemberOnlyNoticeTitle}" />
                        </StackPanel>

                        <TextBlock
                            Grid.Column="4"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            FontSize="11"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="{Binding MemberOnlyNoticeMessage}"
                            TextAlignment="Right"
                            TextWrapping="Wrap" />
                    </Grid>
                </Border>

                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        Text="{Binding EnableFeatureLabel}"
                        FontWeight="SemiBold"
                        VerticalAlignment="Center" />
                    <ui:ToggleSwitch
                        Grid.Column="1"
                        IsEnabled="{Binding IsFeatureToggleEnabled}"
                        IsChecked="{Binding IsFeatureEnabled, Mode=TwoWay}" />
                </Grid>

                <Grid
                    Margin="0,0,0,14"
                    Visibility="{Binding IsSeparateWindowOptionVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        Text="{Binding SeparateWindowLabel}"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <ui:ToggleSwitch
                        Grid.Column="1"
                        IsChecked="{Binding ShowResultsInSeparateWindow, Mode=TwoWay}" />
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Column="0"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Text="{Binding CaptureTargetLabel}" />

                    <ComboBox
                        Grid.Column="1"
                        DisplayMemberPath="DisplayName"
                        IsEnabled="{Binding IsCaptureTargetSelectionEnabled}"
                        ItemsSource="{Binding CaptureTargets}"
                        SelectedItem="{Binding SelectedCaptureTarget}" />

                    <ui:Button
                        Grid.Column="2"
                        Margin="8,0,0,0"
                        Command="{Binding RefreshCaptureTargetsCommand}"
                        Content="{Binding RefreshProcessesLabel}"
                        Appearance="Secondary"
                        Icon="{ui:SymbolIcon ArrowClockwise24}" />
                </Grid>

                <Separator Margin="0,14,0,14" />

                <TextBlock
                    Margin="0,0,0,8"
                    Text="{Binding TargetLanguagesLabel}"
                    FontWeight="SemiBold" />

                <ItemsControl ItemsSource="{Binding PeerTargetLanguages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:PeerAudioLanguageItemViewModel}">
                            <Border
                                Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10,8"
                                Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        Text="{Binding Label}"
                                        VerticalAlignment="Center" />
                                    <ComboBox
                                        Grid.Column="1"
                                        DisplayMemberPath="DisplayName"
                                        ItemsSource="{Binding AvailableLanguages}"
                                        SelectedItem="{Binding SelectedDisplayLanguage}"
                                        IsEnabled="{Binding DataContext.IsPeerTargetLanguageSelectionEnabled, RelativeSource={RelativeSource AncestorType=Page}}" />
                                    <ui:Button
                                        Grid.Column="2"
                                        Margin="8,0,0,0"
                                        Command="{Binding RemoveCommand}"
                                        Appearance="Secondary"
                                        Icon="{ui:SymbolIcon Delete24}"
                                        ToolTip="{Binding RemoveLabel}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ui:Button
                    HorizontalAlignment="Left"
                    Command="{Binding AddPeerTargetLanguageCommand}"
                    Content="{Binding AddLanguageLabel}"
                    Appearance="Secondary"
                    Icon="{ui:SymbolIcon Add24}" />
            </StackPanel>
        </Border>

        <Border
            Grid.Row="2"
            Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12"
            Margin="0,0,0,12">
            <TextBlock
                Text="{Binding StatusText}"
                TextWrapping="Wrap"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </Border>

        <Border
            Grid.Row="3"
            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="12"
            Visibility="{Binding IsEmbeddedResultVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Text="{Binding EmbeddedResultLabel}"
                        FontWeight="SemiBold"
                        VerticalAlignment="Center" />
                    <ui:Button
                        Grid.Column="1"
                        Command="{Binding ClearCommand}"
                        Content="{Binding ClearLabel}"
                        Appearance="Secondary"
                        Icon="{ui:SymbolIcon Delete24}" />
                </Grid>

                <ScrollViewer
                    x:Name="MessagesScrollViewer"
                    Grid.Row="1"
                    VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:PeerAudioChatMessage}">
                                <Border
                                    HorizontalAlignment="Stretch"
                                    Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="12"
                                    Margin="0,0,0,10">
                                    <TextBlock
                                        Text="{Binding Text}"
                                        TextWrapping="Wrap"
                                        FontSize="14" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>
