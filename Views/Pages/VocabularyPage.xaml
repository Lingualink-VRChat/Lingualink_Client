<Page
    x:Class="lingualink_client.Views.VocabularyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:lingualink_client.ViewModels"
    Title="VocabularyPage"
    d:DataContext="{d:DesignInstance Type=vm:VocabularyPageViewModel}"
    d:DesignHeight="800"
    d:DesignWidth="1180"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="HeaderGhostButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="InlineGridTextBoxStyle" TargetType="ui:TextBox">
            <Setter Property="Margin" Value="2" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="{DynamicResource PageContentMargin}">
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock
                        Text="{Binding PageTitle}"
                        Style="{DynamicResource PageTitleTextBlockStyle}" />
                    <TextBlock
                        Margin="0,6,0,0"
                        FontSize="12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{Binding TableCountSummary}" />
                </StackPanel>

                <ui:Button
                    Grid.Column="1"
                    Margin="12,0,0,0"
                    Command="{Binding ImportVocabularyTableCommand}"
                    Content="{Binding ImportLabel}"
                    Icon="{ui:SymbolIcon Symbol=ArrowImport24}" />

                <ui:Button
                    Grid.Column="2"
                    Margin="12,0,0,0"
                    Command="{Binding ExportVocabularyTableCommand}"
                    CommandParameter="{Binding SelectedVocabularyTable}"
                    Content="{Binding ExportLabel}"
                    Icon="{ui:SymbolIcon Symbol=ArrowExport24}"
                    IsEnabled="{Binding HasSelectedVocabularyTable}" />

                <ui:Button
                    Grid.Column="3"
                    Margin="12,0,0,0"
                    Command="{Binding AddVocabularyTableCommand}"
                    Content="{Binding AddTableLabel}"
                    Appearance="Primary"
                    Icon="{ui:SymbolIcon Symbol=Add24}" />
            </Grid>

            <ui:InfoBar
                Margin="0,0,0,20"
                ToolTipService.InitialShowDelay="150"
                Title="{Binding GuidanceTitle}"
                Message="{Binding GuidanceHint}"
                Severity="Informational"
                IsOpen="True"
                IsClosable="False">
                <ui:InfoBar.ToolTip>
                    <ToolTip Placement="Mouse" MaxWidth="520" IsHitTestVisible="False" Focusable="False">
                        <StackPanel>
                            <TextBlock
                                FontWeight="SemiBold"
                                Text="{Binding EntryGuideTitle}" />
                            <TextBlock
                                Margin="0,6,0,0"
                                Text="{Binding TermGuideText}"
                                TextWrapping="Wrap" />
                            <TextBlock
                                Margin="0,4,0,0"
                                Text="{Binding AliasesGuideText}"
                                TextWrapping="Wrap" />
                            <TextBlock
                                Margin="0,4,0,0"
                                Text="{Binding PronunciationsGuideText}"
                                TextWrapping="Wrap" />
                            <Separator Margin="0,10,0,10" />
                            <TextBlock
                                FontWeight="SemiBold"
                                Text="{Binding ExampleTitle}" />
                            <TextBlock
                                Margin="0,6,0,0"
                                Text="{Binding ExampleBody}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </ToolTip>
                </ui:InfoBar.ToolTip>
                <ui:InfoBar.Content>
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="{Binding GuidanceBody}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Margin="0,8,0,0"
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="{Binding SectionHint}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </ui:InfoBar.Content>
            </ui:InfoBar>

            <ItemsControl ItemsSource="{Binding VocabularyTables}" Visibility="{Binding HasSelectedVocabularyTable, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:VocabularyTableEditor}">
                        <ui:Card Margin="0,0,0,16" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border
                                    Grid.Row="0"
                                    Padding="16"
                                    Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Button
                                            Grid.Column="0"
                                            Margin="0,0,12,0"
                                            Command="{Binding DataContext.ToggleVocabularyTableExpansionCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource HeaderGhostButtonStyle}"
                                            ToolTip="{Binding DataContext.ExpandTableLabel, RelativeSource={RelativeSource AncestorType=Page}}">
                                            <TextBlock
                                                FontSize="14"
                                                FontWeight="SemiBold"
                                                Text="{Binding ExpandGlyph}" />
                                        </Button>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <ui:TextBox
                                                MinWidth="220"
                                                MaxWidth="360"
                                                Margin="0"
                                                Padding="0"
                                                BorderThickness="0"
                                                Background="Transparent"
                                                FontSize="16"
                                                FontWeight="SemiBold"
                                                PlaceholderText="{Binding DataContext.TableNamePlaceholder, RelativeSource={RelativeSource AncestorType=Page}}"
                                                Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <Border
                                                Margin="12,0,0,0"
                                                Padding="8,3"
                                                Background="{DynamicResource AccentFillColorSecondaryBrush}"
                                                CornerRadius="10"
                                                Visibility="{Binding Enabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Foreground="White"
                                                    Text="{Binding DataContext.EnabledBadgeLabel, RelativeSource={RelativeSource AncestorType=Page}}" />
                                            </Border>
                                        </StackPanel>

                                        <TextBlock
                                            Grid.Column="2"
                                            Margin="20,0"
                                            VerticalAlignment="Center"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            Text="{Binding HeaderSummary}" />

                                        <RadioButton
                                            Grid.Column="3"
                                            Margin="0,0,16,0"
                                            VerticalAlignment="Center"
                                            GroupName="VocabularyEnabledGroup"
                                            IsChecked="{Binding Enabled, Mode=TwoWay}">
                                            <TextBlock Text="{Binding DataContext.TableEnabledLabel, RelativeSource={RelativeSource AncestorType=Page}}" />
                                        </RadioButton>

                                        <ui:Button
                                            Grid.Column="4"
                                            Command="{Binding DataContext.RemoveVocabularyTableCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Content="{Binding DataContext.DeleteTableLabel, RelativeSource={RelativeSource AncestorType=Page}}"
                                            Icon="{ui:SymbolIcon Symbol=Delete24}" />
                                    </Grid>
                                </Border>

                                <Grid
                                    Grid.Row="1"
                                    Margin="16"
                                    Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock
                                                Style="{DynamicResource BodyStrongTextBlockStyle}"
                                                Text="{Binding DataContext.SelectedTableSummary, RelativeSource={RelativeSource AncestorType=Page}}" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                FontSize="11"
                                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                Text="{Binding DataContext.AliasesHint, RelativeSource={RelativeSource AncestorType=Page}}" />
                                        </StackPanel>

                                        <ui:Button
                                            Grid.Column="1"
                                            Command="{Binding DataContext.AddVocabularyEntryCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Content="{Binding DataContext.AddEntryLabel, RelativeSource={RelativeSource AncestorType=Page}}"
                                            Appearance="Primary"
                                            Icon="{ui:SymbolIcon Symbol=Add24}" />
                                    </Grid>

                                    <DataGrid
                                        Grid.Row="1"
                                        AutoGenerateColumns="False"
                                        CanUserAddRows="False"
                                        CanUserResizeRows="False"
                                        HeadersVisibility="Column"
                                        ItemsSource="{Binding Entries}"
                                        SelectedItem="{Binding DataContext.SelectedVocabularyEntry, RelativeSource={RelativeSource AncestorType=Page}, Mode=TwoWay}"
                                        RowHeaderWidth="0"
                                        MaxHeight="420"
                                        RowHeight="42"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        Background="Transparent"
                                        GridLinesVisibility="Horizontal"
                                        HorizontalGridLinesBrush="{DynamicResource CardStrokeColorDefaultBrush}">
                                        <DataGrid.Columns>
                                            <DataGridCheckBoxColumn Binding="{Binding Enabled, Mode=TwoWay}" Width="60">
                                                <DataGridCheckBoxColumn.Header>
                                                    <TextBlock Text="{Binding DataContext.TableEnabledLabel, RelativeSource={RelativeSource AncestorType=Page}}" />
                                                </DataGridCheckBoxColumn.Header>
                                                <DataGridCheckBoxColumn.ElementStyle>
                                                    <Style TargetType="CheckBox">
                                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                                        <Setter Property="VerticalAlignment" Value="Center" />
                                                    </Style>
                                                </DataGridCheckBoxColumn.ElementStyle>
                                            </DataGridCheckBoxColumn>

                                            <DataGridTemplateColumn Width="180">
                                                <DataGridTemplateColumn.Header>
                                                    <TextBlock Text="{Binding DataContext.EntryTermHeader, RelativeSource={RelativeSource AncestorType=Page}}" />
                                                </DataGridTemplateColumn.Header>
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <ui:TextBox
                                                            Style="{StaticResource InlineGridTextBoxStyle}"
                                                            PlaceholderText="{Binding DataContext.TermPlaceholder, RelativeSource={RelativeSource AncestorType=Page}}"
                                                            ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                                                            Text="{Binding Term, UpdateSourceTrigger=PropertyChanged}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTemplateColumn Width="*">
                                                <DataGridTemplateColumn.Header>
                                                    <TextBlock Text="{Binding DataContext.EntryAliasesHeader, RelativeSource={RelativeSource AncestorType=Page}}" />
                                                </DataGridTemplateColumn.Header>
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <ui:TextBox
                                                            Style="{StaticResource InlineGridTextBoxStyle}"
                                                            PlaceholderText="{Binding DataContext.AliasesPlaceholder, RelativeSource={RelativeSource AncestorType=Page}}"
                                                            ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                                                            Text="{Binding AliasesText, UpdateSourceTrigger=PropertyChanged}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTemplateColumn Width="*">
                                                <DataGridTemplateColumn.Header>
                                                    <TextBlock Text="{Binding DataContext.EntryPronunciationsHeader, RelativeSource={RelativeSource AncestorType=Page}}" />
                                                </DataGridTemplateColumn.Header>
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <ui:TextBox
                                                            Style="{StaticResource InlineGridTextBoxStyle}"
                                                            PlaceholderText="{Binding DataContext.PronunciationsPlaceholder, RelativeSource={RelativeSource AncestorType=Page}}"
                                                            ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                                                            Text="{Binding PronunciationsText, UpdateSourceTrigger=PropertyChanged}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTemplateColumn Width="120">
                                                <DataGridTemplateColumn.Header>
                                                    <TextBlock Text="{Binding DataContext.EntryActionsHeader, RelativeSource={RelativeSource AncestorType=Page}}" />
                                                </DataGridTemplateColumn.Header>
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                            <Button
                                                                Command="{Binding DataContext.MoveVocabularyEntryUpCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource HeaderGhostButtonStyle}"
                                                                ToolTip="{Binding DataContext.MoveEntryUpLabel, RelativeSource={RelativeSource AncestorType=Page}}">
                                                                <TextBlock Text="↑" />
                                                            </Button>
                                                            <Button
                                                                Command="{Binding DataContext.MoveVocabularyEntryDownCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource HeaderGhostButtonStyle}"
                                                                ToolTip="{Binding DataContext.MoveEntryDownLabel, RelativeSource={RelativeSource AncestorType=Page}}">
                                                                <TextBlock Text="↓" />
                                                            </Button>
                                                            <Button
                                                                Command="{Binding DataContext.RemoveVocabularyEntryCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource HeaderGhostButtonStyle}"
                                                                ToolTip="{Binding DataContext.DeleteEntryLabel, RelativeSource={RelativeSource AncestorType=Page}}">
                                                                <TextBlock Foreground="#C42B1C" Text="✕" />
                                                            </Button>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Grid>
                        </ui:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ui:Card
                Padding="32"
                Visibility="{Binding HasSelectedVocabularyTable, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=invert}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ui:SymbolIcon
                        Symbol="TextBulletListLtr24"
                        FontSize="48"
                        Margin="0,0,0,16"
                        Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                    <TextBlock
                        Style="{DynamicResource SubtitleTextBlockStyle}"
                        Text="{Binding NoTablesTitle}"
                        TextAlignment="Center" />
                    <TextBlock
                        Margin="0,8,0,20"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{Binding NoTablesBody}"
                        TextAlignment="Center"
                        TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <ui:Button
                            Margin="0,0,12,0"
                            Command="{Binding AddVocabularyTableCommand}"
                            Content="{Binding AddTableLabel}"
                            Appearance="Primary"
                            Icon="{ui:SymbolIcon Symbol=Add24}" />
                        <ui:Button
                            Command="{Binding ImportVocabularyTableCommand}"
                            Content="{Binding ImportLabel}"
                            Icon="{ui:SymbolIcon Symbol=ArrowImport24}" />
                    </StackPanel>
                </StackPanel>
            </ui:Card>
        </StackPanel>
    </ScrollViewer>
</Page>
